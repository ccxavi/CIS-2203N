<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="todo_list.Components.TodoFormCard"
             x:Name="root">

    <Border BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}"
            Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
            StrokeThickness="1"
            StrokeShape="RoundRectangle 16">
        <Border.Shadow>
            <Shadow Brush="{AppThemeBinding Light=#10000000, Dark=#20000000}"
                    Offset="0,2"
                    Radius="8"
                    Opacity="1"/>
        </Border.Shadow>

        <VerticalStackLayout Padding="20,20" Spacing="12">

            <!-- Title field -->
            <Label Text="TITLE" Style="{StaticResource CardLabel}" Margin="0,0,0,2"/>
            <VerticalStackLayout Spacing="0">
                <Entry x:Name="titleEntry"
                       Placeholder="What needs to be done?"
                       ReturnType="Next"
                       MaxLength="50"
                       BackgroundColor="Transparent"/>
                <BoxView HeightRequest="1"
                         Margin="0,0,0,0"
                         BackgroundColor="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"/>
            </VerticalStackLayout>

            <!-- Details field -->
            <Label Text="DETAILS" Style="{StaticResource CardLabel}" Margin="0,4,0,2"/>
            <Editor x:Name="detailsEditor"
                    Placeholder="Add some details…"
                    MaxLength="240"
                    HeightRequest="88"/>

            <!-- Buttons -->
            <Button x:Name="addBtn"
                    Text="Add To-Do"
                    IsVisible="True"
                    Margin="0,4,0,0"
                    Clicked="OnAddClicked"/>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10" IsVisible="False" x:Name="editRow">
                <Button Grid.Column="0"
                        x:Name="editBtn"
                        Text="Save Changes"
                        Clicked="OnEditClicked"/>
                <Button Grid.Column="1"
                        x:Name="cancelBtn"
                        Text="Cancel"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}"
                        BorderColor="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                        BorderWidth="1"
                        Clicked="OnCancelClicked"/>
            </Grid>

        </VerticalStackLayout>
    </Border>
</ContentView>
