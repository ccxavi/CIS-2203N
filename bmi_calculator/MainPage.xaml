<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:bmi_calculator.Components"
             x:Class="bmi_calculator.MainPage"
             Title="">

    <ScrollView>
        <VerticalStackLayout Padding="24,48,24,40" Spacing="16">

            <VerticalStackLayout Spacing="4" Margin="0,0,0,8">
                <Label Text="BMI Calculator"
                       Style="{StaticResource PageTitle}"/>
                <Label Text="Enter your measurements below"
                       Style="{StaticResource PageSubtitle}"/>
            </VerticalStackLayout>

            <components:InputField
                x:Name="HeightInput"
                Label="HEIGHT"
                Placeholder="0"
                Unit="cm"/>

            <components:InputField
                x:Name="WeightInput"
                Label="WEIGHT"
                Placeholder="0"
                Unit="kg"/>

            <Button Text="Calculate BMI"
                    Clicked="OnCalculateClicked"
                    Margin="0,8,0,0"
                    HorizontalOptions="Fill"/>

            <Button Text="Reset"
                    Clicked="OnResetClicked"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                    BorderColor="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                    BorderWidth="1"
                    HorizontalOptions="Fill"/>

            <components:BmiResultCard
                x:Name="ResultCard"
                IsVisible="False"/>

            <components:BmiHistoryCard
                x:Name="HistoryCard"
                IsVisible="False"/>

            <components:BmiScaleCard/>

            <Label HorizontalTextAlignment="Center"
                   FontFamily="InterRegular"
                   FontSize="11"
                   Margin="0,4,0,0"
                   TextColor="{AppThemeBinding Light={StaticResource Muted}, Dark={StaticResource MutedDark}}">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="Built with ♥ by "/>
                        <Span Text="ccxavi"
                              FontFamily="InterSemiBold"
                              TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}">
                            <Span.GestureRecognizers>
                                <TapGestureRecognizer Tapped="GitHubLink_Tapped"/>
                            </Span.GestureRecognizers>
                        </Span>
                    </FormattedString>
                </Label.FormattedText>
            </Label>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
