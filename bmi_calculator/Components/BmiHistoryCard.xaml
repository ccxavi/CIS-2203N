<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:bmi_calculator.Models"
             x:Class="bmi_calculator.Components.BmiHistoryCard">

    <Border BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}"
            Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
            StrokeThickness="1"
            StrokeShape="RoundRectangle 16">
        <Border.Shadow>
            <Shadow Brush="{AppThemeBinding Light=#10000000, Dark=#20000000}"
                    Offset="0,2"
                    Radius="8"
                    Opacity="1"/>
        </Border.Shadow>

        <VerticalStackLayout Padding="24,24" Spacing="0">

            <!-- Header row -->
            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,16">
                <Label Grid.Column="0"
                       Text="HISTORY"
                       Style="{StaticResource CardLabel}"/>
                <Label Grid.Column="1"
                       x:Name="CountLabel"
                       FontFamily="InterMedium"
                       FontSize="12"
                       TextColor="{AppThemeBinding Light={StaticResource Muted}, Dark={StaticResource MutedDark}}"/>
            </Grid>

            <!-- History list — scrollable after 10 rows -->
            <ScrollView MaximumHeightRequest="520">
                <CollectionView x:Name="HistoryList"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:BmiRecord">
                            <Grid ColumnDefinitions="*,Auto"
                                  Padding="0,10"
                                  RowDefinitions="Auto,Auto">

                                <!-- Category -->
                                <Label Grid.Row="0" Grid.Column="0"
                                       Text="{Binding Category}"
                                       FontFamily="InterSemiBold"
                                       FontSize="14"
                                       TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>

                                <!-- Measurements + timestamp -->
                                <Label Grid.Row="1" Grid.Column="0"
                                       FontFamily="InterRegular"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light={StaticResource Muted}, Dark={StaticResource MutedDark}}"
                                       Margin="0,2,0,0">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{Binding Measurements}"/>
                                            <Span Text="   "/>
                                            <Span Text="{Binding Timestamp}"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>

                                <!-- BMI value -->
                                <Label Grid.Row="0" Grid.Column="1"
                                       Grid.RowSpan="2"
                                       Text="{Binding BmiValue}"
                                       FontFamily="InterBold"
                                       FontSize="22"
                                       TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </ScrollView>

        </VerticalStackLayout>
    </Border>
</ContentView>
